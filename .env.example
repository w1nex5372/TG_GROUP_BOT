BOT_TOKEN = "12345679:ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefg" # Get this from @BotFather.
BOT_USERNAME = "MyBasedBot" # Your bot's username without the "@"
OWNER_ID = "123456789" # Your Telegram user ID, send /id to @getmyid_bot
SUPERUSERS = ["123456789", "987654321"] # List of id's for users which have elevated access to the bot.
LOG_LEVEL = "info" # Log levels: "trace", "debug", "info", "warn", "error", "fatal", "silent". Default to "info".
LOG_CHANNEL = "-100123456789" # To get this, forward a message from channel to @getmyid_bot. Make sure to add the bot in log channel with "post messages" right.
START_GIF = "https://media1.tenor.com/m/VoddPEycQT8AAAAC/cyberpunk-edge-runners.gif" # GIF(direct link or file id) to send when the user uses /start command.
ADDED_TO_CHAT_GIF = "https://media1.tenor.com/m/qvN-956nAroAAAAC/cyberpunk-edgerunners.gif" # GIF(direct link or file id) to send when the user adds the bot in their group chat.
DATABASE_URL = "postgresql://johndoe:randompassword@localhost:5432/mydb?schema=public" # PostgreSQL Database URL.
REDIS_CACHE_URL = "redis://localhost:6379/0" # Redis Cache URL for caching user data.
GRAMJS_API_ID = 123456
GRAMJS_API_HASH = "123456abcdefg"
GRAMJS_STRING_SESSION = "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789"

# --- Clients list (manual commands: /addclient /delclient /clients /postclients) ---
# Bot must be admin (Send Messages) in the target group.
CLIENTS_TARGET_CHAT_ID = "-1003846193977"  # Group to post into
CLIENTS_DELETE_PREVIOUS = "true"           # Delete the previous posted message before posting new
CLIENTS_FIRE_ON_START = "true"             # Post immediately when bot starts

# --- Auto post clients scheduler ---
# Set AUTO_POSTCLIENTS_ENABLED=true to activate periodic re-posting of the clients list.
# Uses CLIENTS_TARGET_CHAT_ID, CLIENTS_DELETE_PREVIOUS, CLIENTS_FIRE_ON_START from above.
AUTO_POSTCLIENTS_ENABLED = "false"
AUTO_POSTCLIENTS_INTERVAL_MINUTES = "15"   # How often to re-post, in minutes

# --- Ads rotator ---
# Set ADS_ENABLED=true to activate the scheduler; all other ADS_* vars are ignored when false.
ADS_ENABLED = "false"
# Private channel message link https://t.me/c/3846193977/57  ->  SOURCE_CHAT_ID=-1003846193977  MESSAGE_ID=57
ADS_SOURCE_CHAT_ID = "-1003846193977"      # Channel the bot will forward FROM (bot must be admin there)
ADS_SOURCE_MESSAGE_IDS = "57,58,59"        # Comma-separated message IDs to rotate through
ADS_TARGET_CHAT_ID = "-100xxxxxxxxxx"      # Group/channel the bot will forward INTO (bot must be admin there)
ADS_INTERVAL_MINUTES = "30"               # Full rotation cycle length in minutes
ADS_SPACING_SECONDS = "120"               # Seconds between individual ads within one cycle
ADS_FIRE_ON_START = "false"               # Set true to send the first cycle immediately on start

# --- Ad publishing workflow (/createad) ---
# Admin-controlled draft → preview → approve → publish flow.
#
# ADS_PUBLISHER_BOT_TOKEN  — the SECOND bot used only for publishing final ads.
#   Get a new bot token from @BotFather.
#   This bot must be:
#     • Added to every target group/channel
#     • In groups   → granted "Send Messages" permission
#     • In channels → made admin with "Post Messages" permission
#   When admin approves an ad, testestoron calls this bot to send the message,
#   so the post appears in the group as coming from the publisher bot, not testestoron.
#
ADS_PUBLISHER_BOT_TOKEN = "98765432:ABCDEFGHIJKLMNOPQRSTUVWXYZpublisher"

# ADS_TARGET_CHAT_ID (above) is used as the first/default publish destination.
# Optionally configure a second destination below.
ADS_TARGET_CHAT_LABEL   = "Pagrindinė grupė"      # Display name for first target (used in UI)
ADS_TARGET_CHAT_ID_2    = ""                       # Optional second publish destination chat ID
ADS_TARGET_CHAT_LABEL_2 = "Reklamos kanalas"       # Display name for second target

# --- Ad queue / traffic control ---
# Controls minimum time between published ads (draft → approve workflow).
ADS_MIN_SPACING_MINUTES = "15"   # Minimum minutes between successive published ads
ADS_QUEUE_ENABLED = "true"       # true = queue ads when spacing blocks; false = reject immediately
ADS_MAX_QUEUE_SIZE = "20"        # Maximum number of ads allowed in queue at once

# --- Ad rotation pool ---
# Permanent ads that rotate automatically when the queue is empty.
# Add ads with /addrotation, manage with /rotationlist and /rotationremove.
ADS_ROTATION_ENABLED = "false"           # true = enable automatic rotation when queue is empty
ADS_ROTATION_INTERVAL_MINUTES = "15"    # Minimum minutes between rotation ad publishes
ADS_ROTATION_RANDOMIZE = "true"         # true = random pick; false = round-robin order

# --- Referral system ---
GROUP_ID = "-1001234567890"              # The group chat_id where users must join to confirm referral
GROUP_INVITE_URL = "https://t.me/+xxxxxxxxxxxx"   # Invite link shown to referred users & in DM menu "👥 Grupė" button
                                                   # Can also be overridden at runtime with /setgroupurl
REF_REQUIRE_GROUP_JOIN = "true"          # Require joining GROUP_ID before crediting referral
REF_JOIN_WINDOW_HOURS = "24"             # Hours the referred user has to join after clicking the link
REF_DAILY_CAP = "20"                     # Max confirmed referrals per referrer per 24h
